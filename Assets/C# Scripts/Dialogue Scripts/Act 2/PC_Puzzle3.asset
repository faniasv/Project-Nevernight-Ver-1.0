%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 786c7bc14905c2f45b560b57ac49e2c3, type: 3}
  m_Name: PC_Puzzle3
  m_EditorClassIdentifier: 
  keepPanelOpenAtEnd: 0
  lines:
  - characterName: AVA
    lineText: Aku ingat ini!
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 9bf943f71623c264885804e87a446f0f, type: 3}
  - characterName: AVA
    lineText: Aku bilang ke Ayah kalau aku ingin jadi astronot agar bisa melihat
      bintang lebih dekat!
    commands: []
  - characterName: MINION
    lineText: Dan di mana bintang yang kamu tuju itu sekarang?
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: bff574c99f1bd214e808cef7cc10fa71, type: 3}
  - characterName: AVA
    lineText: "Aku tidak tahu\u2026"
    commands: []
  - characterName: AVA
    lineText: Aku bahkan sulit percaya bahkan suatu hari aku akan melihat bintang
      itu lagi
    commands: []
  - characterName: MINION
    lineText: Kehidupan dewasa perlahan menelan mimpi masa kecilmu
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 976c5a881d85b4743a5d31f74f6ec50c, type: 3}
  - characterName: MINION
    lineText: Tapi tidak ada kata terlambat
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: f61bb87e9b9ec2e4fb1f598ec9d74239, type: 3}
  - characterName: MINION
    lineText: "Untuk melihat bintang itu bersinar\u2026"
    commands: []
  - characterName: MINION
    lineText: "Yang ada di dalam dirimu\u2026"
    commands: []
  - characterName: AVA
    lineText: "Mungkin\u2026"
    commands: []
  - characterName: AVA
    lineText: Tanpa kusadari, bintang yang paling bersinar adalah diriku sendiri
    commands: []
