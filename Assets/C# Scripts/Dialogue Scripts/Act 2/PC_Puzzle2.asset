%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 786c7bc14905c2f45b560b57ac49e2c3, type: 3}
  m_Name: PC_Puzzle2
  m_EditorClassIdentifier: 
  keepPanelOpenAtEnd: 0
  lines:
  - characterName: MINION
    lineText: Siapa anak kecil ini? Matanya bersinar... dia terlihat sangat berani
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 4763d71988e07334c8795c52a7975d43, type: 3}
  - characterName: AVA
    lineText: Apakah itu aku?
    commands: []
  - characterName: AVA
    lineText: Tangan mungil itu memegang crayon sebanyak itu
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 9bf943f71623c264885804e87a446f0f, type: 3}
  - characterName: MINION
    lineText: Apakah hidupmu sekarang sesuai bayangan Ava saat berusia lima tahun?
    commands: []
  - characterName: AVA
    lineText: Yah, secara pencapaian...
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 3fe5a4721fd08fc47bba1165d066d955, type: 3}
  - characterName: AVA
    lineText: Tapi aku merasa tidak berkarya, hanya mengejar target
    commands: []
  - characterName: AVA
    lineText: Ava versi umur lima tahun itu akan sedih mendengarnya
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 3fe5a4721fd08fc47bba1165d066d955, type: 3}
  - characterName: MINION
    lineText: "Belum tentu\u2026"
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: bff574c99f1bd214e808cef7cc10fa71, type: 3}
  - characterName: MINION
    lineText: Dia pasti bangga dengan dirimu sekarang
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: bf7144a2c7d302f48a72d461613e455a, type: 3}
  - characterName: MINION
    lineText: Lalu, apa yang dirasakan oleh Ava saat ini?
    commands: []
  - characterName: AVA
    lineText: "Aku merasa aku merindukan bagian diriku\u2026"
    commands:
    - type: 1
      value: 
      audioAsset: {fileID: 0}
      spriteAsset: {fileID: 21300000, guid: 5009ad2fa8a51074991cdd49ad87d1ad, type: 3}
  - characterName: AVA
    lineText: Yang menatap karyanya dengan mata berbinar
    commands: []
